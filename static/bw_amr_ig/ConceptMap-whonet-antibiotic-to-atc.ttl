  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: ConceptMap whonet-antibiotic-to-atc</b></p><a name=\"whonet-antibiotic-to-atc\"> </a><a name=\"hcwhonet-antibiotic-to-atc\"> </a><p>Mapping from http://whonet.org/CodeSystem/antibiotic to http://www.whocc.no/atc</p><br/><p><b>Group 1 </b>Mapping from <code>http://whonet.org/CodeSystem/antibiotic</code> to <code>http://www.whocc.no/atc</code> (WHO ATC)</p><table class=\"grid\"><tr><td><b>Source Code</b></td><td><b>Relationship</b></td><td><b>Target Code</b></td></tr><tr><td>AMA (4-aminosalicylic acid)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J04AA01 (Drugs for treatment of tuberculosis)</td></tr><tr><td>ALS (Aldesulfone sodium)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J04BA03 (Drugs for treatment of lepra)</td></tr><tr><td>AMK (Amikacin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>D06AX12,J01GB06,QD06AX12,QJ01GB06,QS01AA21,S01AA21 (Aminoglycoside antibacterials)</td></tr><tr><td>AMO (Amorolfine)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>D01AE16,QD01AE16 (Antifungals for topical use)</td></tr><tr><td>AMX (Amoxicillin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01CA04,QG51AA03,QJ01CA04 (Beta-lactam antibacterials, penicillins)</td></tr><tr><td>AMC (Amoxicillin/clavulanic acid)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01CR02,QJ01CR02 (Beta-lactam antibacterials, penicillins)</td></tr><tr><td>AXS (Amoxicillin/sulbactam)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01CR02,QJ01CR02 (Amoxicillin/sulbactam)</td></tr><tr><td>AMB (Amphotericin B)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>A01AB04,A07AA07,G01AA03,J02AA01,QA01AB04,QA07AA07,QG01AA03,QJ02AA01 (Antimycotics for systemic use)</td></tr><tr><td>AMP (Ampicillin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01CA01,QJ01CA01,QJ51CA01,QS01AA19,S01AA19 (Beta-lactam antibacterials, penicillins)</td></tr><tr><td>SAM (Ampicillin/sulbactam)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01CR01,QJ01CR01 (Beta-lactam antibacterials, penicillins)</td></tr><tr><td>AMR (Amprolium)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>QP51BX02 (Amprolium)</td></tr><tr><td>ANI (Anidulafungin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J02AX06,QJ02AX06 (Antimycotics for systemic use)</td></tr><tr><td>APR (Apramycin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>QA07AA92,QJ01GB90,QJ51GB90 (Apramycin)</td></tr><tr><td>ARB (Arbekacin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01GB12,QJ01GB12 (Arbekacin)</td></tr><tr><td>APX (Aspoxicillin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01CA19,QJ01CA19 (Aspoxicillin)</td></tr><tr><td>AVI (Avilamycin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>QA07AA95 (Avilamycin)</td></tr><tr><td>AZD (Azidocillin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01CE04,QJ01CE04 (Beta-lactam antibacterials, penicillins)</td></tr><tr><td>AZM (Azithromycin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01FA10,QJ01FA10,QS01AA26,S01AA26 (Macrolides, lincosamides and streptogramins)</td></tr><tr><td>AFC (Azithromycin/fluconazole/secnidazole)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01RA07,QJ01RA07 (Combinations of antibacterials)</td></tr><tr><td>AZL (Azlocillin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01CA09,QJ01CA09 (Beta-lactam antibacterials, penicillins)</td></tr><tr><td>ATM (Aztreonam)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01DF01,QJ01DF01 (Other beta-lactam antibacterials)</td></tr><tr><td>AZA (Aztreonam/avibactam)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01DF51,QJ01DF51 (Aztreonam/avibactam)</td></tr><tr><td>ANC (Aztreonam/nacubactam)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01DF51,QJ01DF51 (Aztreonam/nacubactam)</td></tr><tr><td>BAM (Bacampicillin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01CA06,QJ01CA06 (Beta-lactam antibacterials, penicillins)</td></tr><tr><td>BAC (Bacitracin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>D06AX05,J01XX10,QA07AA93,QD06AX05,QJ01XX10,QR02AB04,QS01AA32,R02AB04,S01AA32 (Bacitracin)</td></tr><tr><td>BDQ (Bedaquiline)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J04AK05,QJ04AK05 (Bedaquiline)</td></tr><tr><td>BEK (Bekanamycin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01GB13,QJ01GB13 (Bekanamycin)</td></tr><tr><td>BNB (Benzathine benzylpenicillin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01CE08,QJ01CE08 (Beta-lactam antibacterials, penicillins)</td></tr><tr><td>BNP (Benzathine phenoxymethylpenicillin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01CE10,QJ01CE10 (Beta-lactam antibacterials, penicillins)</td></tr><tr><td>PEN (Benzylpenicillin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01CE01,QJ01CE01,QJ51CE01,QS01AA14,S01AA14 (Combinations of antibacterials)</td></tr><tr><td>BES (Besifloxacin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>QS01AE08,S01AE08 (Besifloxacin)</td></tr><tr><td>BIA (Biapenem)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01DH05,QJ01DH05 (Biapenem)</td></tr><tr><td>BLM (Bleomycin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>L01DC01,QL01DC01 (Bleomycin)</td></tr><tr><td>BDP (Brodimoprim)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01EA02,QJ01EA02 (Sulfonamides and trimethoprim)</td></tr><tr><td>BUT (Butoconazole)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>G01AF15,QG01AF15 (Butoconazole)</td></tr><tr><td>CLA (Calcium aminosalicylate)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J04AA03,QJ04AA03 (Drugs for treatment of tuberculosis)</td></tr><tr><td>CAP (Capreomycin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J04AB30,QJ04AB30 (Drugs for treatment of tuberculosis)</td></tr><tr><td>CRB (Carbenicillin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01CA03,QJ01CA03 (Beta-lactam antibacterials, penicillins)</td></tr><tr><td>CRN (Carindacillin)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01CA05,QJ01CA05 (Beta-lactam antibacterials, penicillins)</td></tr><tr><td>CAR (Carumonam)</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>J01DF02,QJ01DF02 (Carumonam)</td></tr><tr><td>CAS (Caspofungin)</td><td><a hr